{
  "entities": {
    "PrintJob": {
      "title": "PrintJob",
      "description": "Represents a print job",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "printerId": { "type": "string" },
        "fileName": { "type": "string" },
        "fileType": { "type": "string" },
        "fileSize": { "type": "number" },
        "fileId": { "type": "string" },
        "copies": { "type": "number" },
        "colorMode": { "type": "string" },
        "paperSize": { "type": "string" },
        "status": { "type": "string" },
        "statusMessage": { "type": "string" },
        "retryCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "printerId", "fileName", "fileId", "status", "createdAt", "updatedAt"]
    },
    "Printer": {
      "title": "Printer",
      "description": "Represents a printer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "location": { "type": "string" },
        "status": { "type": "string" },
        "lastSeen": { "type": "string", "format": "date-time" },
        "apiKey": { "type": "string" },
        "jobCount": { "type": "number" }
      },
      "required": ["id", "name", "status", "apiKey"]
    }
  },
  "firestore": {
    "/jobs/{jobId}": {
      "schema": "PrintJob",
      "description": "Collection of all print jobs"
    },
    "/printers/{printerId}": {
      "schema": "Printer",
      "description": "Collection of all printers"
    }
  }
}
